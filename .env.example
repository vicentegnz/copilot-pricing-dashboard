# ─────────────────────────────────────────────────────────────────────────────
# copilot-ometer — environment configuration
# Copy this file to .env.local and adjust values as needed.
# ─────────────────────────────────────────────────────────────────────────────

# Path to the GitHub Copilot CLI session-state directory.
# Default (when unset): ~/.copilot/session-state  (auto-detected via os.homedir())
# Override when running in Docker or when your data lives elsewhere.
#
# Examples:
#   Linux/macOS native:  COPILOT_SESSION_DIR=/home/yourname/.copilot/session-state
#   Docker (volume):     COPILOT_SESSION_DIR=/data/sessions
#   Windows (WSL):       COPILOT_SESSION_DIR=/mnt/c/Users/YourName/.copilot/session-state
#
# COPILOT_SESSION_DIR=
